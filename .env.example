# IBERDROLA_GATEWAY_TOKEN — ThingsBoard PE gateway access token
# For Mode B (direct TB PE connection)
# DO NOT commit real tokens — use .env.local or environment variables
IBERDROLA_GATEWAY_TOKEN=REPLACE_WITH_REAL_TOKEN

# Simulator configuration
SIMULATOR_HOST=0.0.0.0
SIMULATOR_PORT=8000
SIMULATOR_LOG_LEVEL=info